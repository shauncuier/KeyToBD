# =========================
# KeytoBD Booking Plugin .gitignore
# =========================

# ----- Package managers -----
node_modules/
vendor/

# ----- Build & compiled output -----
dist/
build/

# ----- Caches -----
.sass-cache/
.cache/

# ----- Source maps -----
*.map

# ----- Environment -----
.env
.env.*
!.env.example

# ----- OS generated files -----
.DS_Store
Thumbs.db

# ----- IDE / editor files -----
.vscode/
.idea/

# ----- Debug -----
debug.log
error_log

# ----- Test artifacts -----
.phpunit.result.cache
coverage/

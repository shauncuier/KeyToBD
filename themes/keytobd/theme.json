{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 2,
  "settings": {
    "appearanceTools": true,
    "layout": {
      "contentSize": "720px",
      "wideSize": "1200px"
    },
    "color": {
      "custom": true,
      "customGradient": true,
      "defaultPalette": false,
      "palette": [
        { "slug": "navy",       "color": "#0E2F44", "name": "Sea Navy" },
        { "slug": "blue",       "color": "#1E6F8E", "name": "Ocean" },
        { "slug": "sky",        "color": "#2A8DA8", "name": "Shallow Water" },
        { "slug": "sky-soft",   "color": "#E6F4F1", "name": "Misty Teal" },
        { "slug": "accent",     "color": "#FF6B35", "name": "Sunset" },
        { "slug": "accent-dark","color": "#E8551F", "name": "Sunset Dark" },
        { "slug": "teal",       "color": "#1FB6A6", "name": "Lagoon Teal" },
        { "slug": "green",      "color": "#2E7D5B", "name": "Palm Green" },
        { "slug": "ink",        "color": "#14202B", "name": "Ink" },
        { "slug": "muted",      "color": "#5B6B7A", "name": "Muted Text" },
        { "slug": "line",       "color": "#E2E9EE", "name": "Hairline" },
        { "slug": "white",      "color": "#FFFFFF", "name": "White" },
        { "slug": "sand",       "color": "#F7F2E9", "name": "Warm Sand" },
        { "slug": "cloud",      "color": "#FBFBF8", "name": "Cloud" }
      ],
      "gradients": [
        { "slug": "hero", "name": "Hero Overlay", "gradient": "linear-gradient(180deg, rgba(14,47,68,0.15) 0%, rgba(14,47,68,0.82) 100%)" },
        { "slug": "brand", "name": "Brand", "gradient": "linear-gradient(135deg, #1E6F8E 0%, #0E2F44 100%)" }
      ]
    },
    "typography": {
      "customFontSize": true,
      "fluid": true,
      "fontFamilies": [
        {
          "fontFamily": "'Poppins', system-ui, -apple-system, Segoe UI, Roboto, sans-serif",
          "slug": "heading",
          "name": "Heading"
        },
        {
          "fontFamily": "'Inter', system-ui, -apple-system, Segoe UI, Roboto, Helvetica, Arial, sans-serif",
          "slug": "body",
          "name": "Body"
        }
      ],
      "fontSizes": [
        { "slug": "small",   "size": "0.875rem", "name": "Small" },
        { "slug": "medium",  "size": "1rem",     "name": "Medium" },
        { "slug": "large",   "size": "1.25rem",  "name": "Large" },
        { "slug": "x-large", "size": "1.75rem",  "name": "Extra Large" },
        { "slug": "xx-large","size": "clamp(2rem, 1.2rem + 3vw, 3.25rem)", "name": "Display" }
      ]
    },
    "spacing": {
      "units": ["px", "em", "rem", "vh", "vw", "%"],
      "spacingScale": { "steps": 8 }
    }
  },
  "styles": {
    "color": { "background": "var(--wp--preset--color--white)", "text": "var(--wp--preset--color--ink)" },
    "typography": {
      "fontFamily": "var(--wp--preset--font-family--body)",
      "fontSize": "1rem",
      "lineHeight": "1.65"
    },
    "elements": {
      "heading": { "typography": { "fontFamily": "var(--wp--preset--font-family--heading)", "fontWeight": "700", "lineHeight": "1.2" } },
      "link": { "color": { "text": "var(--wp--preset--color--blue)" } },
      "button": {
        "color": { "background": "var(--wp--preset--color--accent)", "text": "var(--wp--preset--color--white)" },
        "border": { "radius": "10px" },
        "typography": { "fontWeight": "600" }
      }
    }
  }
}

# Theme: keytobd — build artifacts & local cruft

# Dependencies / build output
node_modules/
vendor/
dist/
build/

# Bundled plugin zip — build artifact, regenerate via bin/build-plugin-zip.sh
assets/required-plugins/*.zip

# Compiled CSS sourcemaps (keep main.css; ignore generated maps)
assets/css/*.css.map
.sass-cache/
*.scssc

# Caveman-compress backups (FILE.original.md) and editor temp
*.original.md
*.swp
*~

# Compiled translations (keep .po, ignore generated .mo if built locally)
languages/*.mo

# OS / editor
.DS_Store
Thumbs.db
.idea/
.vscode/
